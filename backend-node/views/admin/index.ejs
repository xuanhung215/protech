<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <title>VitaStore Admin</title>
  <link rel="stylesheet" href="/static/admin/css/style.css?v=1" />
</head>
<body>
  <div class="admin-layout">
    <%- include('fragments/sidebar') %>

    <div class="main-wrap">
      <header class="topbar">
        <div class="topbar-info">
          <div class="topbar-title" id="topbarTitle">Dashboard</div>
          <div class="topbar-breadcrumb">Tổng quan hệ thống</div>
        </div>
        <div class="topbar-right">
          <div class="dropdown">
            <button class="icon-btn" id="settingsBtn" title="Cài đặt" onclick="toggleLogoutDropdown()">⚙️</button>
            <div class="dropdown-menu" id="logoutDropdown" style="display: none">
              <button class="dropdown-item dropdown-item-logout" onclick="logout()">❌ Đăng xuất</button>
            </div>
          </div>
        </div>
      </header>

      <div class="page-wrap">
        <div class="page-header">
          <div>
            <div class="page-title">Tổng quan</div>
            <div class="page-subtitle" id="dashDate">—</div>
          </div>
          <button class="btn btn-outline" onclick="loadDashboard()">🔄 Làm mới</button>
        </div>

        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon blue">💰</div>
            <div>
              <div class="stat-val" id="statRevenue">—</div>
              <div class="stat-label">Doanh thu (đơn hoàn thành)</div>
              <div class="stat-change up" id="statRevenueChange">↑ loading...</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon cyan">📦</div>
            <div>
              <div class="stat-val" id="statOrders">—</div>
              <div class="stat-label">Tổng đơn hàng</div>
              <div class="stat-change up" id="statPending">— đơn chờ xử lý</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon green">🛍</div>
            <div>
              <div class="stat-val" id="statProducts">—</div>
              <div class="stat-label">Sản phẩm còn hàng</div>
              <div class="stat-change down" id="statLowStock">— sắp hết hàng</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon orange">👥</div>
            <div>
              <div class="stat-val" id="statUsers">—</div>
              <div class="stat-label">Người dùng</div>
              <div class="stat-change up" id="statDiscounts">— mã giảm giá active</div>
            </div>
          </div>
        </div>

        <div class="grid-2" style="margin-bottom: 20px">
          <div class="card">
            <div class="card-header">
              <div><div class="card-title">📈 Doanh thu 7 ngày gần nhất</div><div class="card-subtitle">Đơn vị: VNĐ</div></div>
            </div>
            <div style="padding: 20px">
              <div class="chart-placeholder" id="revenueChart">
                <div class="chart-bar"></div><div class="chart-bar"></div><div class="chart-bar"></div>
                <div class="chart-bar"></div><div class="chart-bar"></div><div class="chart-bar"></div><div class="chart-bar"></div>
              </div>
              <div class="chart-labels"><span>T2</span><span>T3</span><span>T4</span><span>T5</span><span>T6</span><span>T7</span><span>CN</span></div>
            </div>
          </div>
          <div class="card">
            <div class="card-header"><div class="card-title">🏆 Top sản phẩm đánh giá cao</div></div>
            <div style="padding: 6px 20px 16px" id="topProductsList"></div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <div class="card-title">📋 Đơn hàng gần đây</div>
            <a href="/admin/order/list" class="btn btn-sm btn-outline">Xem tất cả →</a>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr><th>Order Code</th><th>Khách hàng</th><th>Tổng tiền</th><th>Trạng thái</th><th>Ngày tạo</th></tr>
              </thead>
              <tbody id="recentOrdersBody"><tr><td colspan="5" style="text-align:center;padding:40px;color:var(--text-muted)">Đang tải...</td></tr></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="/static/admin/js/admin.js"></script>
  <script>
    async function loadDashboard() {
      document.getElementById("dashDate").textContent = new Date().toLocaleDateString("vi-VN", { weekday: "long", year: "numeric", month: "long", day: "numeric" });

      try {
        const s = await API.getDashboardStats();
        document.getElementById("statRevenue").textContent = Utils.formatCurrency(s.totalRevenue);
        document.getElementById("statOrders").textContent = s.totalOrders;
        document.getElementById("statPending").textContent = `⏳ ${s.pendingOrders} đơn chờ xử lý`;

        document.getElementById("recentOrdersBody").innerHTML = (s.recentOrders || []).length
          ? s.recentOrders.map(o => `<tr><td class="td-mono"><strong>${o.orderCode}</strong></td><td>${o.userName || 'Guest'}</td><td style="font-weight:700;color:var(--primary)">${Utils.formatCurrency(o.totalAmount)}</td><td>${Utils.statusBadge(o.status)}</td><td class="td-mono">${new Date(o.createdAt).toLocaleDateString('vi-VN')}</td></tr>`).join("")
          : `<tr><td colspan="5" style="text-align:center;padding:40px;color:var(--text-muted)">Chưa có đơn hàng nào</td></tr>`;

        document.getElementById("topProductsList").innerHTML = (s.bestSellingProducts || []).map(p =>
          `<div style="display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:1px solid var(--border)">
            <div><div style="font-size:13px;font-weight:600">${p.productName}</div><div style="margin-top:3px">Đã bán: ${p.totalSold}</div></div>
            <div style="font-size:13px;font-weight:700;color:var(--primary)">${Utils.formatCurrency(p.totalRevenue)}</div>
          </div>`).join("");
      } catch(e) {
        console.error('Dashboard load error:', e);
      }
    }

    setActiveNav("dashboard");
    document.addEventListener("DOMContentLoaded", loadDashboard);
  </script>
</body>
</html>
