<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>VitaStore – Admin Login</title>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --primary: #3ecfb2;
      --primary-dark: #29b89b;
      --primary-light: #e6faf6;
      --bg: #f0f4f8;
      --text: #1a2e3b;
      --text-muted: #6b7c8d;
      --border: #e2eaf0;
      --danger: #e05252;
    }
    body {
      font-family: "Be Vietnam Pro", sans-serif;
      background: var(--bg);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      position: relative;
      overflow: hidden;
    }
    body::before, body::after {
      content: "";
      position: fixed;
      border-radius: 50%;
      pointer-events: none;
    }
    body::before {
      width: 600px; height: 600px;
      background: radial-gradient(circle, rgba(62,207,178,0.12) 0%, transparent 70%);
      top: -200px; right: -150px;
    }
    body::after {
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(41,184,155,0.08) 0%, transparent 70%);
      bottom: -120px; left: -100px;
    }
    .login-card {
      width: 100%; max-width: 420px;
      background: #fff; border-radius: 20px;
      padding: 44px 44px 36px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.09), 0 2px 8px rgba(62,207,178,0.1);
      position: relative; z-index: 1;
      animation: popIn 0.5s cubic-bezier(0.22, 0.68, 0, 1.2) both;
    }
    @keyframes popIn {
      from { transform: translateY(24px) scale(0.97); opacity: 0; }
      to { transform: translateY(0) scale(1); opacity: 1; }
    }
    .logo-wrap { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 32px; }
    .logo-icon {
      width: 42px; height: 42px;
      background: linear-gradient(135deg, #3ecfb2, #29b89b);
      border-radius: 11px; display: flex; align-items: center; justify-content: center;
      font-size: 22px; box-shadow: 0 4px 14px rgba(62,207,178,0.35);
    }
    .logo-text { line-height: 1.2; }
    .logo-name { font-size: 18px; font-weight: 700; color: var(--text); letter-spacing: -0.3px; }
    .logo-sub { font-size: 10px; font-weight: 600; color: var(--primary); letter-spacing: 2px; text-transform: uppercase; }
    .divider { height: 1px; background: var(--border); margin-bottom: 28px; }
    .login-heading { margin-bottom: 24px; text-align: center; }
    .login-heading h1 { font-size: 22px; font-weight: 700; color: var(--text); letter-spacing: -0.4px; margin-bottom: 5px; }
    .login-heading p { font-size: 13.5px; color: var(--text-muted); line-height: 1.5; }
    .form-group { margin-bottom: 18px; }
    label { display: block; font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 7px; }
    .input-wrap { position: relative; }
    .input-wrap svg.field-icon {
      position: absolute; left: 13px; top: 50%; transform: translateY(-50%);
      color: var(--text-muted); pointer-events: none; width: 16px; height: 16px;
    }
    input[type="text"], input[type="password"] {
      width: 100%; padding: 11px 13px 11px 40px;
      border: 1.5px solid var(--border); border-radius: 10px;
      font-family: inherit; font-size: 14px; color: var(--text);
      background: #fafcff; outline: none;
      transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }
    input:focus { border-color: var(--primary); background: #fff; box-shadow: 0 0 0 3px rgba(62,207,178,0.15); }
    input::placeholder { color: #b8c6d0; }
    .eye-toggle {
      position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
      background: none; border: none; cursor: pointer;
      color: var(--text-muted); padding: 2px; display: flex; align-items: center;
      transition: color 0.2s;
    }
    .eye-toggle:hover { color: var(--primary); }
    .form-options {
      display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;
    }
    .btn-login {
      width: 100%; padding: 12px;
      background: linear-gradient(135deg, #3ecfb2 0%, #29b89b 100%);
      border: none; border-radius: 10px; color: #fff;
      font-family: inherit; font-size: 15px; font-weight: 600;
      cursor: pointer; letter-spacing: 0.1px;
      box-shadow: 0 6px 18px rgba(62,207,178,0.35);
      transition: transform 0.15s, box-shadow 0.15s, filter 0.15s;
    }
    .btn-login:hover { transform: translateY(-1px); box-shadow: 0 8px 22px rgba(62,207,178,0.45); filter: brightness(1.04); }
    .error-msg {
      display: none; background: #fff5f5; border: 1px solid #fcc;
      border-radius: 8px; padding: 9px 13px; margin-bottom: 16px;
      font-size: 13px; color: var(--danger); align-items: center; gap: 8px;
    }
    .error-msg.show { display: flex; }
    .card-footer { text-align: center; margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--border); font-size: 12px; color: var(--text-muted); }
    .loading-overlay {
      position: fixed; inset: 0; background: rgba(255,255,255,0.65);
      backdrop-filter: blur(4px); display: none;
      align-items: center; justify-content: center; z-index: 100;
    }
    .loading-overlay.show { display: flex; }
    .spinner {
      width: 38px; height: 38px;
      border: 3px solid var(--primary-light); border-top-color: var(--primary);
      border-radius: 50%; animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="logo-wrap">
      <div class="logo-icon">🌿</div>
      <div class="logo-text">
        <div class="logo-name">VitaStore</div>
        <div class="logo-sub">Admin Panel</div>
      </div>
    </div>
    <div class="divider"></div>
    <div class="login-heading">
      <h1>Đăng nhập quản trị</h1>
      <p>Nhập thông tin tài khoản để truy cập hệ thống</p>
    </div>

    <div class="error-msg <%= error ? 'show' : '' %>" id="errorMsg">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <span id="errorText"><%= error || 'Tên đăng nhập hoặc mật khẩu không đúng.' %></span>
    </div>

    <form id="loginForm">
      <div class="form-group">
        <label for="username">Tên đăng nhập</label>
        <div class="input-wrap">
          <svg class="field-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <input type="text" id="username" placeholder="Nhập tên đăng nhập" autocomplete="username" />
        </div>
      </div>
      <div class="form-group">
        <label for="password">Mật khẩu</label>
        <div class="input-wrap">
          <svg class="field-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
          <input type="password" id="password" placeholder="Nhập mật khẩu" autocomplete="current-password" />
          <button type="button" class="eye-toggle" id="eyeToggle">
            <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
          </button>
        </div>
      </div>
      <div class="form-options">
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;user-select:none;font-size:13px;color:var(--text-muted)">
          <input type="checkbox" id="rememberMe" style="display:none" />
          <div style="width:16px;height:16px;border:1.5px solid var(--border);border-radius:4px;background:#fafcff;display:flex;align-items:center;justify-content:center" id="checkboxBox"></div>
          <span>Ghi nhớ đăng nhập</span>
        </label>
        <a href="#" class="forgot-link" style="font-size:13px;color:var(--primary);text-decoration:none;font-weight:500">Quên mật khẩu?</a>
      </div>
      <button type="submit" class="btn-login" id="loginBtn">Đăng nhập</button>
    </form>

    <div class="card-footer">© 2026 VitaStore Admin Panel · Phiên bản 1.0.0</div>
  </div>

  <div class="loading-overlay" id="loadingOverlay"><div class="spinner"></div></div>

  <script>
    const eyeToggle = document.getElementById("eyeToggle");
    const pwInput = document.getElementById("password");
    const eyeIcon = document.getElementById("eyeIcon");
    const eyeOpen = `<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>`;
    const eyeClose = `<path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>`;

    eyeToggle.addEventListener("click", () => {
      const show = pwInput.type === "password";
      pwInput.type = show ? "text" : "password";
      eyeIcon.innerHTML = show ? eyeClose : eyeOpen;
    });

    document.getElementById("loginForm").addEventListener("submit", async function(e) {
      e.preventDefault();
      const user = document.getElementById("username").value.trim();
      const pass = document.getElementById("password").value;
      const loadingOverlay = document.getElementById("loadingOverlay");
      const loginBtn = document.getElementById("loginBtn");
      const err = document.getElementById("errorMsg");
      err.classList.remove("show");

      if (!user || !pass) {
        document.getElementById("errorText").textContent = "Vui lòng nhập đầy đủ tên đăng nhập và mật khẩu.";
        err.classList.add("show");
        return;
      }

      loadingOverlay.classList.add("show");
      loginBtn.disabled = true;

      try {
        const res = await fetch("/api/auth/login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify({ username: user, password: pass }),
        });

        if (!res.ok) {
          const errorBody = await res.json().catch(() => ({}));
          document.getElementById("errorText").textContent = errorBody.message || "Tên đăng nhập hoặc mật khẩu không đúng.";
          err.classList.add("show");
          return;
        }

        loginBtn.textContent = "✓ Đăng nhập thành công!";
        loginBtn.style.background = "linear-gradient(135deg,#28c840,#1da832)";
        loginBtn.style.boxShadow = "0 6px 18px rgba(40,200,64,0.35)";
        window.location.href = "/admin";
      } catch (error) {
        document.getElementById("errorText").textContent = "Không thể kết nối tới máy chủ. Vui lòng thử lại.";
        err.classList.add("show");
      } finally {
        loadingOverlay.classList.remove("show");
        loginBtn.disabled = false;
      }
    });
  </script>
</body>
</html>
